# Core app
NODE_ENV=development
CORE_PORT=3000
CORE_HOST=0.0.0.0
AUTH_ISSUER=http://localhost:3000
AUTH_ISSUER_INTERNAL=http://zauth-core:3000
API_BASE_URL=http://localhost:3000
UI_BASE_URL=http://localhost:3001
VERIFY_BASE_URL=http://localhost:3000
RP_ID=localhost
EXPECTED_ORIGIN=http://localhost:3000
SESSION_COOKIE_SECURE=false
SESSION_TTL_SECONDS=28800
AUTH_REQUEST_TTL_SECONDS=900
TENANT_SALT=change-me-dev-salt
LIVENESS_MODE=challenge
LIVENESS_MIN_CONFIDENCE=0.72
PRAMAAN_V2_ENABLED=true
AUTH_REQUIRE_ZK_FOR_LOGIN=false
ZK_VERIFIER_MODE=mock
ZK_CIRCUIT_ID=biometric_commitment_v1
ZK_VERIFY_KEY_PATH=zk/verification_key.json
ZK_REQUIRE_CHALLENGE_BINDING=true
ANCHOR_ENABLED=false
ANCHOR_INTERVAL_HOURS=24
ANCHOR_CHAIN_RPC_URL=
ANCHOR_CHAIN_CONTRACT=
ANCHOR_PRIVATE_KEY=
ANCHOR_IPFS_API=

# Database + Redis
POSTGRES_DB=zauth
POSTGRES_USER=zauth
POSTGRES_PASSWORD=zauth_dev_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
REDIS_URL=redis://redis:6379

# UI
UI_PORT=3001
DEMO_CLIENT_ID=demo-web-client
DEMO_REDIRECT_URI=http://localhost:3001/callback
NOTES_PORT=3002
NOTES_HOST=0.0.0.0
NOTES_BASE_URL=http://localhost:3002
NOTES_APP_ORIGIN=http://localhost:5173
NOTES_CLIENT_ID=notes-web-client
NOTES_REDIRECT_URI=http://localhost:3002/callback
NOTES_REQUIRED_ACR=urn:zauth:aal1
NOTES_CSRF_SECRET=change-me-notes-csrf-dev
NOTES_LOGIN_RATE_WINDOW_MS=60000
NOTES_LOGIN_RATE_MAX=20
NOTES_CALLBACK_RATE_WINDOW_MS=60000
NOTES_CALLBACK_RATE_MAX=40

# Caddy
CADDY_EMAIL=admin@geturstyle.shop
