NODE_ENV=production
CORE_PORT=3000
CORE_HOST=0.0.0.0
AUTH_ISSUER=https://auth.geturstyle.shop
AUTH_ISSUER_INTERNAL=http://zauth-core:3000
API_BASE_URL=https://api.geturstyle.shop
UI_BASE_URL=https://console.geturstyle.shop
VERIFY_BASE_URL=https://verify.geturstyle.shop
RP_ID=auth.geturstyle.shop
EXPECTED_ORIGIN=https://auth.geturstyle.shop
SESSION_COOKIE_SECURE=true
SESSION_TTL_SECONDS=28800
AUTH_REQUEST_TTL_SECONDS=900
TENANT_SALT=replace-with-random-long-secret
LIVENESS_MODE=challenge
LIVENESS_MIN_CONFIDENCE=0.74
PRAMAAN_V2_ENABLED=true
AUTH_REQUIRE_ZK_FOR_LOGIN=true
ZK_VERIFIER_MODE=real
ZK_CIRCUIT_ID=biometric_commitment_v1
ZK_VERIFY_KEY_PATH=zk/verification_key.json
ZK_REQUIRE_CHALLENGE_BINDING=true
ANCHOR_ENABLED=true
ANCHOR_INTERVAL_HOURS=24
ANCHOR_CHAIN_RPC_URL=https://rpc-amoy.polygon.technology/
ANCHOR_CHAIN_CONTRACT=0xYourDeployedContractAddress
ANCHOR_PRIVATE_KEY=replace-with-anchor-wallet-private-key
ANCHOR_IPFS_API=https://api.pinata.cloud
ANCHOR_PINATA_JWT=replace-with-pinata-jwt-token
IDENTITY_CHAIN_ENABLED=false
IDENTITY_CHAIN_RPC_URL=https://sepolia.base.org
IDENTITY_CHAIN_CONTRACT=0xYourDeployedIdentityContractAddress
IDENTITY_CHAIN_PRIVATE_KEY=replace-with-identity-chain-wallet-private-key
POSTGRES_DB=zauth
POSTGRES_USER=zauth
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
REDIS_URL=redis://redis:6379
UI_PORT=3001
DEMO_CLIENT_ID=demo-web-client
DEMO_REDIRECT_URI=https://demo.geturstyle.shop/callback
NOTES_PORT=3002
NOTES_HOST=0.0.0.0
NOTES_BASE_URL=https://notes.geturstyle.shop
NOTES_APP_ORIGIN=https://notes.geturstyle.shop
NOTES_CLIENT_ID=notes-web-client
NOTES_REDIRECT_URI=https://notes.geturstyle.shop/callback
NOTES_REQUIRED_ACR=urn:zauth:aal2:zk
NOTES_CSRF_SECRET=replace-with-random-notes-csrf-secret
NOTES_LOGIN_RATE_WINDOW_MS=60000
NOTES_LOGIN_RATE_MAX=20
NOTES_CALLBACK_RATE_WINDOW_MS=60000
NOTES_CALLBACK_RATE_MAX=40
CADDY_EMAIL=admin@geturstyle.shop

# Optional GitHub packages image tags used by deploy scripts
ZAUTH_CORE_IMAGE=ghcr.io/your-org/zauth-core:latest
ZAUTH_UI_IMAGE=ghcr.io/your-org/zauth-ui:latest
ZAUTH_NOTES_IMAGE=ghcr.io/your-org/zauth-notes:latest
